# Virtual environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Test/cache/coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Logs and temp files
*.log
*.tmp
*.bak
*.swp
*.swo

# Local editor/OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# Reports generated by ActiveRecon
reports/*
!reports/.gitkeep
report.md
report.json

# Local inventory/scope output generated by examples and discovery
inventories/*
!inventories/.gitkeep
scopes/*
!scopes/.gitkeep
.pytest_tmp/
.tmp/

# Build/package output
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Local secrets/config
.env
.env.*
